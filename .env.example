APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

LOCAL_AI_ENDPOINT=
LOCAL_AI_MODEL=llama3.1

# AI provider selection: local, gemini, fallback
AI_PROVIDER=local
# Optional: external Gemini-style endpoint and API key. If using Gemini, set AI_PROVIDER=gemini
GEMINI_API_ENDPOINT=
GEMINI_API_KEY=
AI_MODEL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

IDP_ENABLED=true
IDP_BASE_URL=https://identity-provider.isaxbsit2027.com
IDP_AUTH_URL=https://identity-provider.isaxbsit2027.com/api/v1/auth/authorize
IDP_AUTH_REQUEST_MODE=login
IDP_LOGIN_PATH=/login
IDP_CALLBACK_URL=
IDP_CLIENT_ID=
IDP_CLIENT_SECRET=
IDP_TOKEN_URL=https://identity-provider.isaxbsit2027.com/api/v1/auth/token
IDP_ME_URL=https://identity-provider.isaxbsit2027.com/api/v1/me
## IDP_FALLBACK_EMAIL removed (fallback login disabled)
IDP_VERIFY_TLS=true
IDP_ENFORCE_STATE=false

AUDIT_LOG_PRUNE_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=730
